#!/usr/bin/make -f
# SPDX-License-Identifier: GPL-3.0-or-later
#
# Build veiland the same way as the Arch/Fedora packages: cargo build
# --release --locked restricted to the real set. We override dh's build/
# test/install steps rather than use dh-cargo, so all three distro
# packages build identically.

export CARGO_HOME = $(CURDIR)/debian/cargo-home
export CARGO_TARGET_DIR = $(CURDIR)/target

CRATES = \
 -p veiland-core \
 -p veiland-wallpaper \
 -p veiland-clock \
 -p veiland-particles \
 -p veiland-vignette \
 -p veiland-label \
 -p veiland-sakura \
 -p veiland-snow \
 -p veiland-rain \
 -p veiland-embers \
 -p veiland-fireflies \
 -p veiland-gradient \
 -p veiland-parallax \
 -p veiland-blobs \
 -p veiland-raymarcher

# Test set: the shipped crates plus the library crates compiled into
# them. `cargo test -p` only runs the named packages' tests, so the
# libraries need their own -p flags or their suites never run.
# Test-only; they produce no installed artifact.
TEST_CRATES = $(CRATES) \
 -p veiland-protocol \
 -p veiland-plugin \
 -p veiland-text

%:
	dh $@

override_dh_auto_build:
	cargo build --release --locked $(CRATES)

override_dh_auto_test:
	# spawn_true_exits_zero needs /bin/true; present here, so no skip.
	cargo test --release --locked $(TEST_CRATES)

override_dh_auto_install:
	# Files are staged by dh_install (debian/veiland.install) and
	# dh_installpam (debian/veiland.pam); the default cargo install is
	# not what we want, so this override is intentionally empty.

execute_after_dh_install:
	# dh_install can't rename. The example config must land as
	# config.example.toml — the name the Arch and RPM packages install,
	# the name its own usage comment tells users to cp, and the name the
	# CI install-check asserts.
	mv debian/veiland/usr/share/veiland/veiland.example.toml \
	   debian/veiland/usr/share/veiland/config.example.toml
	# The hotplug repro config is a dev tool, not a scene. The remaining
	# examples' asset paths are repo-relative (so they run in place from
	# a checkout); point the installed copies at the installed wallpaper.
	rm debian/veiland/usr/share/veiland/examples/hotplug-repro.toml
	sed -i 's|docs/examples/assets/|/usr/share/veiland/|' \
	   debian/veiland/usr/share/veiland/examples/*.toml
